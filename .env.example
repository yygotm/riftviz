# Riot Games API
API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PUUID=your_puuid_here
# PLATFORM: JP1=Japan, NA1=North America, EUW1=EU West, KR=Korea, etc.
PLATFORM=JP1

# Report language used by all scripts: ja or en
# (lol_html_viewer_auto.py and analyzer.py both read this as the default)
LANG=ja

# AI providers (at least one required for Step 3)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
